	<array>
		<string>Ionicons.ttf</string>
		<string>JosefinSans_300Light.ttf</string>
		<string>JosefinSans_400Regular.ttf</string>
		<string>JosefinSans_500Medium.ttf</string>
		<string>JosefinSans_600SemiBold.ttf</string>
		<string>JosefinSans_700Bold.ttf</string>
	</array>
