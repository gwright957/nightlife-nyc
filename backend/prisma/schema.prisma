generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VenueType {
  bar
  club
}

enum LineLength {
  none
  short
  medium
  long
}

enum PointsLedgerType {
  rating
  video
}

enum RewardTier {
  tier_1
  tier_2
  tier_3
}

enum RewardClaimStatus {
  pending
  contacted
}

enum FriendRequestStatus {
  pending
  accepted
  declined
  cancelled
}

enum NotificationType {
  friend_request_received
  friend_request_accepted
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  fullName     String
  birthday     DateTime
  points       Int      @default(0)
  referralCode String   @unique
  referredById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  referredBy       User?      @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referralsMade    User[]     @relation("UserReferrals")
  referrals        Referral[] @relation("ReferrerReferrals")
  referralReceived Referral?  @relation("ReferredUserReferral")
  ratings          Rating[]
  videoSubmissions VideoSubmission[]
  pointsLedger     PointsLedger[]
  rewardClaims     RewardClaim[]
  friendshipsA     Friendship[]    @relation("FriendshipUserA")
  friendshipsB     Friendship[]    @relation("FriendshipUserB")
  sentFriendRequests     FriendRequest[] @relation("SentFriendRequests")
  receivedFriendRequests FriendRequest[] @relation("ReceivedFriendRequests")
  notifications          Notification[]
  notificationsActed     Notification[]  @relation("NotificationActor")

  @@index([referredById])
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email, createdAt])
}

model Venue {
  id        String    @id @default(cuid())
  name      String
  address   String
  lat       Float
  lng       Float
  type      VenueType
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  ratings          Rating[]
  videoSubmissions VideoSubmission[]

  @@index([lat, lng])
}

model Rating {
  id         String     @id @default(cuid())
  userId     String
  venueId    String
  litScore    Int
  genderRatio Int
  lineLength  LineLength
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, createdAt])
  @@index([userId])
}

model VideoSubmission {
  id        String   @id @default(cuid())
  userId    String
  venueId   String
  videoUrl  String
  duration  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, createdAt])
  @@index([userId])
}

model PointsLedger {
  id            String           @id @default(cuid())
  userId        String
  type          PointsLedgerType
  pointsAwarded Int
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RewardClaim {
  id         String            @id @default(cuid())
  userId     String
  rewardTier RewardTier
  status     RewardClaimStatus @default(pending)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Referral {
  id             String   @id @default(cuid())
  referrerId     String
  referredUserId String   @unique
  referredEmail  String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  referrer     User @relation("ReferrerReferrals", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser User @relation("ReferredUserReferral", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([referrerId])
}

model Friendship {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userA User @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model FriendRequest {
  id          String              @id @default(cuid())
  fromUserId  String
  toUserId    String
  status      FriendRequestStatus @default(pending)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  respondedAt DateTime?

  fromUser User @relation("SentFriendRequests", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("ReceivedFriendRequests", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId, status])
  @@index([fromUserId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  actorId   String?
  entityId  String?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, readAt, createdAt])
  @@index([userId, createdAt])
}
