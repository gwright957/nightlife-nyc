generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VenueType {
  bar
  club
}

enum LineLength {
  none
  short
  medium
  long
}

enum PointsLedgerType {
  rating
  video
}

enum RewardTier {
  tier_1
  tier_2
  tier_3
}

enum RewardClaimStatus {
  pending
  contacted
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  fullName     String
  birthday     DateTime
  points       Int      @default(0)
  referralCode String   @unique
  referredById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  referredBy       User?      @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referralsMade    User[]     @relation("UserReferrals")
  referrals        Referral[] @relation("ReferrerReferrals")
  referralReceived Referral?  @relation("ReferredUserReferral")
  ratings          Rating[]
  videoSubmissions VideoSubmission[]
  pointsLedger     PointsLedger[]
  rewardClaims     RewardClaim[]

  @@index([referredById])
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email, createdAt])
}

model Venue {
  id        String    @id @default(cuid())
  name      String
  address   String
  lat       Float
  lng       Float
  type      VenueType
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  ratings          Rating[]
  videoSubmissions VideoSubmission[]

  @@index([lat, lng])
}

model Rating {
  id         String     @id @default(cuid())
  userId     String
  venueId    String
  litScore    Int
  genderRatio Int
  lineLength  LineLength
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, createdAt])
  @@index([userId])
}

model VideoSubmission {
  id        String   @id @default(cuid())
  userId    String
  venueId   String
  videoUrl  String
  duration  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, createdAt])
  @@index([userId])
}

model PointsLedger {
  id            String           @id @default(cuid())
  userId        String
  type          PointsLedgerType
  pointsAwarded Int
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RewardClaim {
  id         String            @id @default(cuid())
  userId     String
  rewardTier RewardTier
  status     RewardClaimStatus @default(pending)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Referral {
  id             String   @id @default(cuid())
  referrerId     String
  referredUserId String   @unique
  referredEmail  String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  referrer     User @relation("ReferrerReferrals", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser User @relation("ReferredUserReferral", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([referrerId])
}
