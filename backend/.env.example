# NeonDB connection string (use pooled URL for serverless)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Server
PORT=3001
NODE_ENV=development
JWT_SECRET="generate-a-long-random-string"
JWT_EXPIRES_IN="30d"

# Object storage (Cloudflare R2 or AWS S3)
STORAGE_PROVIDER="r2"
S3_BUCKET="nightlife-videos"
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
S3_PUBLIC_URL="https://pub-xxx.r2.dev"

# Email (Resend)
RESEND_API_KEY=""
REWARD_CLAIM_EMAIL="gavinwright957@gmail.com"
EMAIL_FROM="NightLife NYC <onboarding@resend.dev>"

# CORS
CORS_ORIGIN="*"

# Mapbox Geocoding (scripts/geocode-venues.ts)
MAPBOX_ACCESS_TOKEN=""
# Optional: default input CSV path if not passed as CLI arg
# VENUE_CSV_INPUT="/path/to/manhattan_brooklyn_bars_clubs_with_50_more.csv"
# GEOCODE_DELAY_MS=150
